{
  "compilerOptions": {
    /* المسارات الأساسية */
    "rootDir": "./src",
    "outDir": "./dist",

    /* لغة البرمجة والبيئة */
    "target": "ES6",
    "module": "CommonJS",

    /* إعدادات المخرجات (تم إيقاف الـ declaration لمنع زحمة الملفات) */
    "declaration": false,
    "sourceMap": false,

    /* الحماية والتحقق */
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}